programa{
	funcao inicio(){
		inteiro tabuleiro[3][2] = { {1, 2}, {3, 4}, {5, 6} }
		
		escreva(tabuleiro[0][0], " ", tabuleiro[0][1], "\n")
		escreva(tabuleiro[1][0], " ", tabuleiro[1][1], "\n")
		escreva(tabuleiro[2][0], " ", tabuleiro[2][1])
	}
}
